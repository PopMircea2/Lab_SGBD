<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Laborator_V2.MainWindow"
        Title="Gestiune Baze de Date - Core ADO.NET"
        Width="1100" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">

        <!-- Status bar -->
        <Border Grid.Row="0" Background="#ECEFF1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Name="StatusText" Text="Ready"/>
        </Border>

        <!-- Two grids side by side -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *">
            <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,5,0">
                <TextBlock Grid.Row="0" Text="Tabel Părinte (Vatertabelle)" FontSize="15" FontWeight="Bold"
                           Margin="0,0,0,5" Foreground="#1565C0"/>
                <DataGrid Grid.Row="1" Name="ParentGrid" IsReadOnly="True" AutoGenerateColumns="False"
                          HeadersVisibility="All" GridLinesVisibility="All"
                          BorderThickness="1" BorderBrush="#CFD8DC"
                          SelectionChanged="ParentGrid_SelectionChanged"/>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto, *" Margin="5,0,0,0">
                <TextBlock Grid.Row="0" Text="Tabel Copil (Kindtabelle)" FontSize="15" FontWeight="Bold"
                           Margin="0,0,0,5" Foreground="#2E7D32"/>
                <DataGrid Grid.Row="1" Name="ChildGrid" IsReadOnly="True" AutoGenerateColumns="False"
                          HeadersVisibility="All" GridLinesVisibility="All"
                          BorderThickness="1" BorderBrush="#CFD8DC"
                          SelectionChanged="ChildGrid_SelectionChanged"/>
            </Grid>
        </Grid>

        <!-- Form + buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,10,0,0">

            <!-- Dynamic form fields -->
            <Border Grid.Column="0" BorderBrush="#B0BEC5" BorderThickness="1"
                    CornerRadius="5" Padding="10">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Text="Date Înregistrare Copil"
                               FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,5" Foreground="#546E7A"/>
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <WrapPanel Name="DynamicFormPanel" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Action buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                        Spacing="10" Margin="15,0,0,0" Width="160">
                <Button Name="BtnInsert" Content="Adaugă (Insert)"
                        Background="#2E7D32" Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10" Click="BtnInsert_Click"/>
                <Button Name="BtnUpdate" Content="Modifică (Update)"
                        Background="#1565C0" Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10" Click="BtnUpdate_Click"/>
                <Button Name="BtnDelete" Content="Șterge (Delete)"
                        Background="#C62828" Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Padding="10" Click="BtnDelete_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
